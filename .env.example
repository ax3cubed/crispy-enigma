# ─── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── LTI Core ─────────────────────────────────────────────────────────────────
# Random string used to sign/encrypt ltijs cookies and internal tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LTI_KEY=change-this-to-a-random-64-char-hex-string

# Path to the SQLite database used by ltijs-sequelize for platform/token storage
LTI_DB_PATH=./lti.db

# Path to the SQLite database used by the application for assessments/rubrics/scores
APP_DB_PATH=./app.db

# ─── saLTIre Platform Config ───────────────────────────────────────────────────
# Fill these in after registering the tool with saLTIre (https://saltire.lti.app/)
# saLTIre will provide the values below when you create a new platform configuration.
PLATFORM_URL=https://saltire.lti.app
PLATFORM_CLIENT_ID=
PLATFORM_AUTH_ENDPOINT=https://saltire.lti.app/platform/auth
PLATFORM_TOKEN_ENDPOINT=https://saltire.lti.app/platform/token
PLATFORM_JWKS_URL=https://saltire.lti.app/platform/jwks

# ─── Tool Public URL ───────────────────────────────────────────────────────────
# The publicly accessible URL for this tool (needed for OIDC redirect validation).
# Use ngrok or similar for local development: https://abc123.ngrok.io
TOOL_BASE_URL=http://localhost:3000
